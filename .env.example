# PostgreSQL connection used by Prisma at runtime and by migration commands.
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public canonical origin used by metadata, Open Graph, robots, and sitemap.
APP_BASE_URL="https://parthsinha.com"

# Optional ownership token from Google Search Console.
GOOGLE_SITE_VERIFICATION=""

# Admin authentication. Use unique, high-entropy values in every environment.
ADMIN_PASSWORD="replace-with-a-strong-password"
SESSION_SECRET="replace-with-at-least-32-random-bytes"

# Cloudflare R2 S3-compatible API configuration.
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY="replace-with-r2-access-key-id"
R2_SECRET_KEY="replace-with-r2-secret-access-key"
R2_BUCKET="replace-with-bucket-name"
R2_BASE_URL="https://media.example.com"

# Optional Cloudflare API token for provisioning/management; not used for uploads.
R2_TOKEN=""
